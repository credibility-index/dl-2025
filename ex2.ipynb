 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Домашнее задание: Multi-Branch MLP для Wine Quality\\n",
    "Цель: Реализовать multi-branch модель и добиться F1 score ≥ 40%"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "import os\\n",
    "os.environ['KMP_DUPLICATE_LIB_OK'] = 'TRUE'\\n",
    "\\n",
    "import warnings\\n",
    "warnings.filterwarnings('ignore')\\n",
    "\\n",
    "import torch\\n",
    "import torch.nn as nn\\n",
    "import numpy as np\\n",
    "import matplotlib.pyplot as plt\\n",
    "import seaborn as sns\\n",
    "import pandas as pd\\n",
    "from sklearn.utils.class_weight import compute_class_weight\\n",
    "import sys\\n",
    "sys.path.append('../../lesson3/seminar')\\n",
    "from wine_quality_data import WineQualityDataModule\\n",
    "from lightning_module import BaseLightningModule\\n",
    "from utils import set_seed\\n",
    "from pytorch_lightning import Trainer\\n",
    "\\n",
    "sns.set_style('whitegrid')\\n",
    "set_seed(42)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Загрузка и анализ данных"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Загружаем данные\\n",
    "dm = WineQualityDataModule(batch_size=128)\\n",
    "dm.setup()\\n",
    "\\n",
    "print(f'Train samples: {len(dm.train_dataset)}')\\n",
    "print(f'Val samples: {len(dm.val_dataset)}')\\n",
    "print(f'Input dim: {dm.input_dim}')\\n",
    "print(f'Num classes: {dm.n_classes}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 1.1. Анализ дисбаланса классов"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Получите метки классов из train_dataset\\n",
    "train_labels = []\\n",
    "for i in range(len(dm.train_dataset)):\\n",
    "    _, y = dm.train_dataset[i]\\n",
    "    train_labels.append(y)\\n",
    "train_labels = np.array(train_labels)\\n",
    "\\n",
    "# Постройте гистограмму распределения классов\\n",
    "plt.figure(figsize=(10, 6))\\n",
    "plt.hist(train_labels, bins=range(3, 11), alpha=0.7, color='steelblue', edgecolor='black')\\n",
    "plt.title('Распределение классов в тренировочном наборе', fontsize=14)\\n",
    "plt.xlabel('Класс (оценка качества вина)', fontsize=12)\\n",
    "plt.ylabel('Количество образцов', fontsize=12)\\n",
    "plt.xticks(range(3, 10))\\n",
    "plt.grid(True, alpha=0.3)\\n",
    "plt.show()\\n",
    "\\n",
    "# Вычислите веса классов используя compute_class_weight\\n",
    "class_weights = compute_class_weight('balanced', classes=np.unique(train_labels), y=train_labels)\\n",
    "class_weights_tensor = torch.FloatTensor(class_weights)\\n",
    "\\n",
    "print(f'Class weights: {class_weights}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Реализация блоков"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "from abc import ABC, abstractmethod\\n",
    "\\n",
    "class BaseMLPBlock(nn.Module, ABC):\\n",
    "    \\\"\\\"\\\"Базовый класс для MLP блока\\\"\\\"\\\"\\n",
    "    def __init__(self, dim, activation='gelu', dropout=0.0):\\n",
    "        super().__init__()\\n",
    "        self.dim = dim\\n",
    "        self.activation = {'relu': nn.ReLU(), 'gelu': nn.GELU(), 'swish': nn.SiLU()}.get(activation, nn.GELU())\\n",
    "        self.dropout = nn.Dropout(dropout) if dropout > 0 else None\\n",
    "    \\n",
    "    @abstractmethod\\n",
    "    def forward(self, x):\\n",
    "        pass\\n",
    "\\n",
    "class BottleneckBlock(BaseMLPBlock):\\n",
    "    \\\"\\\"\\\"Bottleneck блок: dim → dim//4 → dim\\\"\\\"\\\"\\n",
    "    def __init__(self, dim, activation='gelu', dropout=0.0):\\n",
    "        super().__init__(dim, activation, dropout)\\n",
    "        self.bottleneck_dim = max(dim // 4, 1)\\n",
    "        self.fc1 = nn.Linear(self.dim, self.bottleneck_dim)\\n",
    "        self.fc2 = nn.Linear(self.bottleneck_dim, self.dim)\\n",
    "    \\n",
    "    def forward(self, x):\\n",
    "        identity = x\\n",
    "        out = self.fc1(x)\\n",
    "        out = self.activation(out)\\n",
    "        if self.dropout:\\n",
    "            out = self.dropout(out)\\n",
    "        out = self.fc2(out)\\n",
    "        return out + identity\\n",
    "\\n",
    "class InvertedBottleneckBlock(BaseMLPBlock):\\n",
    "    \\\"\\\"\\\"Inverted Bottleneck блок: dim → dim*4 → dim\\\"\\\"\\\"\\n",
    "    def __init__(self, dim, expansion_factor=4, activation='gelu', dropout=0.0):\\n",
    "        super().__init__(dim, activation, dropout)\\n",
    "        self.expanded_dim = dim * expansion_factor\\n",
    "        self.fc1 = nn.Linear(self.dim, self.expanded_dim)\\n",
    "        self.fc2 = nn.Linear(self.expanded_dim, self.dim)\\n",
    "    \\n",
    "    def forward(self, x):\\n",
    "        identity = x\\n",
    "        out = self.fc1(x)\\n",
    "        out = self.activation(out)\\n",
    "        if self.dropout:\\n",
    "            out = self.dropout(out)\\n",
    "        out = self.fc2(out)\\n",
    "        return out + identity\\n",
    "\\n",
    "class RegularBlock(BaseMLPBlock):\\n",
    "    \\\"\\\"\\\"Regular блок: dim → hidden_dim → dim\\\"\\\"\\\"\\n",
    "    def __init__(self, dim, hidden_dim=None, activation='gelu', dropout=0.0):\\n",
    "        super().__init__(dim, activation, dropout)\\n",
    "        self.hidden_dim = hidden_dim if hidden_dim else dim * 2\\n",
    "        self.fc1 = nn.Linear(self.dim, self.hidden_dim)\\n",
    "        self.fc2 = nn.Linear(self.hidden_dim, self.dim)\\n",
    "    \\n",
    "    def forward(self, x):\\n",
    "        identity = x\\n",
    "        out = self.fc1(x)\\n",
    "        out = self.activation(out)\\n",
    "        if self.dropout:\\n",
    "            out = self.dropout(out)\\n",
    "        out = self.fc2(out)\\n",
    "        return out + identity\\n",
    "\\n",
    "# Тестируем блоки\\n",
    "print('✓ Блоки успешно определены!')\\n",
    "test_x = torch.randn(4, 64)\\n",
    "print(f'  Input shape: {test_x.shape}')\\n",
    "bottleneck = BottleneckBlock(64)\\n",
    "print(f'  BottleneckBlock output: {bottleneck(test_x).shape}')\\n",
    "inverted = InvertedBottleneckBlock(64)\\n",
    "print(f'  InvertedBottleneckBlock output: {inverted(test_x).shape}')\\n",
    "regular = RegularBlock(64)\\n",
    "print(f'  RegularBlock output: {regular(test_x).shape}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Multi-Branch модель"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "class MultiBranchMLP(nn.Module):\\n",
    "    \\\"\\\"\\\"\\n",
    "    Multi-Branch MLP с тремя параллельными ветками.\\n",
    "    \\\"\\\"\\\"\\n",
    "    def __init__(\\n",
    "        self,\\n",
    "        input_dim,\\n",
    "        hidden_dim,\\n",
    "        output_dim,\\n",
    "        num_blocks=4,\\n",
    "        dropout=0.1,\\n",
    "        combine_mode='concat'\\n",
    "    ):\\n",
    "        super().__init__()\\n",
    "        self.output_dim = output_dim\\n",
    "        self.combine_mode = combine_mode\\n",
    "        \\n",
    "        # Входная проекция\\n",
    "        self.input_proj = nn.Sequential(\\n",
    "            nn.Linear(input_dim, hidden_dim),\\n",
    "            nn.GELU(),\\n",
    "            nn.Dropout(dropout)\\n",
    "        )\\n",
    "        \\n",
    "        # Создайте три ветки (branches)\\n",
    "        self.bottleneck_branch = nn.ModuleList([\\n",
    "            BottleneckBlock(hidden_dim, activation='gelu', dropout=dropout)\\n",
    "            for _ in range(num_blocks)\\n",
    "        ])\\n",
    "        \\n",
    "        self.inverted_branch = nn.ModuleList([\\n",
    "            InvertedBottleneckBlock(hidden_dim, expansion_factor=4, activation='gelu', dropout=dropout)\\n",
    "            for _ in range(num_blocks)\\n",
    "        ])\\n",
    "        \\n",
    "        self.regular_branch = nn.ModuleList([\\n",
    "            RegularBlock(hidden_dim, hidden_dim=hidden_dim*2, activation='gelu', dropout=dropout)\\n",
    "            for _ in range(num_blocks)\\n",
    "        ])\\n",
    "        \\n",
    "        # Выходная проекция\\n",
    "        if combine_mode == 'concat':\\n",
    "            combined_dim = hidden_dim * 3\\n",
    "        else:\\n",
    "            combined_dim = hidden_dim\\n",
    "            \\n",
    "        self.output_proj = nn.Linear(combined_dim, output_dim)\\n",
    "    \\n",
    "    def forward(self, x):\\n",
    "        # 1. Входная проекция\\n",
    "        x = self.input_proj(x)\\n",
    "        \\n",
    "        # 2. Пропустите через каждую ветку\\n",
    "        bottleneck_out = x\\n",
    "        for block in self.bottleneck_branch:\\n",
    "            bottleneck_out = block(bottleneck_out)\\n",
    "        \\n",
    "        inverted_out = x\\n",
    "        for block in self.inverted_branch:\\n",
    "            inverted_out = block(inverted_out)\\n",
    "        \\n",
    "        regular_out = x\\n",
    "        for block in self.regular_branch:\\n",
    "            regular_out = block(regular_out)\\n",
    "        \\n",
    "        # 3. Объедините результаты\\n",
    "        if self.combine_mode == 'concat':\\n",
    "            combined = torch.cat([bottleneck_out, inverted_out, regular_out], dim=1)\\n",
    "        else:\\n",
    "            combined = bottleneck_out + inverted_out + regular_out\\n",
    "        \\n",
    "        # 4. Выходная проекция\\n",
    "        output = self.output_proj(combined)\\n",
    "        return output\\n",
    "\\n",
    "print('Multi-Branch модель определена!')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Код обучения"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "def train_model(\\n",
    "    model,\\n",
    "    dm,\\n",
    "    class_weights=None,\\n",
    "    max_epochs=50,\\n",
    "    lr=1e-3,\\n",
    "    optimizer_type='adam'\\n",
    "):\\n",
    "    \\\"\\\"\\\"\\n",
    "    Обучает модель с weighted loss.\\n",
    "    \\\"\\\"\\\"\\n",
    "    # Создайте loss function\\n",
    "    if class_weights is not None:\\n",
    "        if isinstance(class_weights, np.ndarray):\\n",
    "            class_weights = torch.FloatTensor(class_weights)\\n",
    "        loss_fn = nn.CrossEntropyLoss(weight=class_weights)\\n",
    "    else:\\n",
    "        loss_fn = nn.CrossEntropyLoss()\\n",
    "    \\n",
    "    lightning_model = BaseLightningModule(\\n",
    "        model=model,\\n",
    "        loss_fn=loss_fn,\\n",
    "        optimizer_type=optimizer_type,\\n",
    "        learning_rate=lr,\\n",
    "        task_type='multiclass'\\n",
    "    )\\n",
    "    \\n",
    "    trainer = Trainer(\\n",
    "        max_epochs=max_epochs,\\n",
    "        enable_checkpointing=False,\\n",
    "        logger=False,\\n",
    "        enable_progress_bar=True,\\n",
    "        enable_model_summary=False\\n",
    "    )\\n",
    "    trainer.fit(lightning_model, dm)\\n",
    "    \\n",
    "    metrics = trainer.callback_metrics\\n",
    "    return {\\n",
    "        'val_acc': metrics.get('val_accuracy', 0).item(),\\n",
    "        'val_f1': metrics.get('val_f1_macro', 0).item()\\n",
    "    }"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Подбор гиперпараметров (опционально)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Быстрый подбор гиперпараметров\\n",
    "print(\"=== Быстрый подбор гиперпараметров ===\\n\")\\n",
    "\\n",
    "configs = [\\n",
    "    {'hidden_dim': 128, 'num_blocks': 4, 'lr': 1e-3, 'opt': 'adam'},\\n",
    "    {'hidden_dim': 128, 'num_blocks': 6, 'lr': 1e-3, 'opt': 'adamw'},\\n",
    "    {'hidden_dim': 256, 'num_blocks': 4, 'lr': 1e-4, 'opt': 'adamw'},\\n",
    "    {'hidden_dim': 256, 'num_blocks': 6, 'lr': 1e-3, 'opt': 'adam'},\\n",
    "]\\n",
    "\\n",
    "best_score = 0\\n",
    "best_config = None\\n",
    "\\n",
    "for config in configs:\\n",
    "    print(f\"Testing: hidden_dim={config['hidden_dim']}, blocks={config['num_blocks']}, lr={config['lr']}, opt={config['opt']}\")\\n",
    "    \\n",
    "    model = MultiBranchMLP(\\n",
    "        input_dim=dm.input_dim,\\n",
    "        hidden_dim=config['hidden_dim'],\\n",
    "        output_dim=dm.n_classes,\\n",
    "        num_blocks=config['num_blocks'],\\n",
    "        dropout=0.1,\\n",
    "        combine_mode='concat'\\n",
    "    )\\n",
    "    \\n",
    "    result = train_model(\\n",
    "        model,\\n",
    "        dm,\\n",
    "        class_weights=class_weights_tensor,\\n",
    "        max_epochs=30,\\n",
    "        lr=config['lr'],\\n",
    "        optimizer_type=config['opt']\\n",
    "    )\\n",
    "    \\n",
    "    print(f\"  -> F1: {result['val_f1']:.4f}, Acc: {result['val_acc']:.4f}\\n\")\\n",
    "    \\n",
    "    if result['val_f1'] > best_score:\\n",
    "        best_score = result['val_f1']\\n",
    "        best_config = config\\n",
    "\\n",
    "print(f\"\\nЛучшая конфигурация: {best_config} с F1={best_score:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Итоговая модель"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "# Обучаем финальную модель с лучшими параметрами\\n",
    "print(\"=== Обучение финальной модели ===\\n\")\\n",
    "\\n",
    "# Если подбор не выполнялся, используем стандартные параметры\\n",
    "if best_config is None:\\n",
    "    best_config = {'hidden_dim': 128, 'num_blocks': 6, 'lr': 1e-3, 'opt': 'adamw'}\\n",
    "\\n",
    "final_model = MultiBranchMLP(\\n",
    "    input_dim=dm.input_dim,\\n",
    "    hidden_dim=best_config['hidden_dim'],\\n",
    "    output_dim=dm.n_classes,\\n",
    "    num_blocks=best_config['num_blocks'],\\n",
    "    dropout=0.1,\\n",
    "    combine_mode='concat'\\n",
    ")\\n",
    "\\n",
    "final_results = train_model(\\n",
    "    final_model,\\n",
    "    dm,\\n",
    "    class_weights=class_weights_tensor,\\n",
    "    max_epochs=100,\\n",
    "    lr=best_config['lr'],\\n",
    "    optimizer_type=best_config['opt']\\n",
    ")\\n",
    "\\n",
    "print(f'\\n=== Итоговые результаты ===')\\n",
    "print(f\"F1 score: {final_results['val_f1']:.4f}\")\\n",
    "print(f\"Accuracy: {final_results['val_acc']:.4f}\")\\n",
    "\\n",
    "if final_results['val_f1'] >= 0.4:\\n",
    "    print(\"\\n✅ Успех! Модель достигла F1 score ≥ 40%!\")\\n",
    "else:\\n",
    "    print(f\"\\n⚠️ F1 score = {final_results['val_f1']:.4f} (< 40%)\")\\n",
    "    print(\"Попробуйте увеличить количество эпох или изменить параметры\")"
   ]
  }
 ]
